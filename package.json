{
  "name": "cinnamona-bakery-refactor",
  "version": "1.0.0",
  "private": true,
  "description": "Side-by-side Next.js refactor copy of the Golden Sweet website",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "start": "cross-env NODE_ENV=production node server.js",
    "content:build": "node scripts/build-content-files.js",
    "content:strip-static": "node scripts/strip-static-i18n-html.js",
    "content:validate:keys": "node scripts/validate-content-keys.js",
    "content:validate:parity": "node scripts/validate-content-parity.js",
    "content:validate:no-static": "node scripts/validate-no-static-fallback.js",
    "content:validate:quality": "node scripts/validate-translation-quality.js",
    "content:validate": "npm run content:validate:parity && npm run content:validate:keys && npm run content:validate:no-static && npm run content:validate:quality"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "next": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "license": "UNLICENSED"
}
